# FastAPI Server Configurations
PROJECT_NAME="ContractAI Backend"
API_V1_STR="/api/v1"
SECRET_KEY="your-super-secret-random-key-change-this-in-production"
ACCESS_TOKEN_EXPIRE_MINUTES=11520 # 8 days

# Database Configurations
# For local development, SQLite is the default fallback.
DATABASE_URL="sqlite+aiosqlite:///./sql_app.db"
# Example PostgreSQL database connection:
# DATABASE_URL="postgresql+asyncpg://postgres.your-project-id:your-password@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# OpenAI API Settings
OPENAI_API_KEY="your-openai-api-key"

# Supabase Storage Configurations
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_KEY="your-supabase-service-role-key-or-anon-key"
SUPABASE_BUCKET_LOGOS="company-logos"
SUPABASE_BUCKET_TEMPLATES="contract-templates"
SUPABASE_BUCKET_CONTRACTS="generated-contracts"
SUPABASE_BUCKET_DOCUMENTS="uploaded-documents"
SUPABASE_BUCKET_SIGNATURES="digital-signatures"
SUPABASE_BUCKET_AVATARS="avatars"

# SMTP / FastAPI-Mail Settings
MAIL_USERNAME="your-email@gmail.com"
MAIL_PASSWORD="your-email-password-or-app-pass"
MAIL_FROM="noreply@contractai.com"
MAIL_PORT=587
MAIL_SERVER="smtp.gmail.com"
MAIL_STARTTLS=True
MAIL_SSL_TLS=False
USE_MOCK_EMAIL=True # Set to False to use actual SMTP

# Storage Settings
LOCAL_STORAGE_DIR="./local_storage" # Fallback local directory if Supabase URL/Key is not provided
